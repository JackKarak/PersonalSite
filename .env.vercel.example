# Copy these into your Vercel project environment variables.
# For local testing only, you can also put them in a local .env file.

NODE_ENV=production
OAUTH_PROVIDER=github

# Your GitHub OAuth App credentials
OAUTH_CLIENT_ID=replace_with_github_client_id
OAUTH_CLIENT_SECRET=replace_with_github_client_secret

# GitHub Pages admin origin (no trailing slash)
ORIGIN=https://jackkarak.github.io

# Must point to your Vercel complete endpoint
COMPLETE_URL=https://YOUR-VERCEL-PROJECT.vercel.app/api/complete

# Optional debug when troubleshooting locally
# DEBUG=netlify-cms-oauth-provider-node*
